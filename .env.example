# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored so secrets never reach the repo.
#
# Variables MUST be prefixed with REACT_APP_ so Create React App
# exposes them to the client bundle at build time.

# Required for the Prompt Simulator page.
# Generate one at https://aistudio.google.com/app/apikey
REACT_APP_GEMINI_API_KEY=your-google-generative-language-api-key

# Optional. Defaults to gemini-3.1-pro-preview if unset.
REACT_APP_GEMINI_MODEL=gemini-3.1-pro-preview
